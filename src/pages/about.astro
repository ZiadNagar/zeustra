---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PAGE_SEO } from "@/data/pagesSeo";
import Footer from "../components/layout/Footer.astro";
import AboutSocialConnectSection from "../features/about/sections/AboutSocialConnectSection.astro";
import AboutOpenPositionsSection from "@/features/about/sections/AboutOpenPositionsSection";
import { type TeamMember } from "@/features/about/data/aboutPageData";
import HeroSection from "@/features/about/sections/HeroSection";
import LeadershipSection from "@/features/about/sections/LeadershipSection";
import { fetchTeamMembers } from "@/lib/strapi";
import Header from "../components/layout/Header.astro";

export const prerender = false;

Astro.response.headers.set("Cache-Control", "no-store, max-age=0");

const resolvedTeamMembers = await fetchTeamMembers();
const serializedTeamMembers: TeamMember[] = resolvedTeamMembers.map(
  (member) => ({
    ...member,
  }),
);
---

<BaseLayout
  title={PAGE_SEO.about.title}
  description={PAGE_SEO.about.description}
  keywords={PAGE_SEO.about.keywords}
  canonical={PAGE_SEO.about.path}
>
  <div class="min-h-screen overflow-x-hidden bg-black text-white">
    <Header currentPathname={Astro.url.pathname} />

    <main class="relative flex-1 overflow-hidden bg-black">
      <HeroSection client:load />
      <LeadershipSection members={serializedTeamMembers} client:load />
      <AboutSocialConnectSection />
      <AboutOpenPositionsSection client:load />
    </main>

    <Footer />
  </div>
</BaseLayout>
