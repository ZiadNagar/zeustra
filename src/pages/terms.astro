---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import { fetchTermsAndConditions } from "@/lib/strapi";

export const prerender = false;

Astro.response.headers.set("Cache-Control", "no-store, max-age=0");

const termsData = await fetchTermsAndConditions();

const formattedDate = termsData.effectiveDate
  ? new Date(termsData.effectiveDate).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<BaseLayout
  title="Zeustra | Terms and Conditions"
  description="Read the Terms and Conditions for using Zeustra's services and products."
  canonical="/terms"
>
  <div class="min-h-screen overflow-x-hidden text-white">
    <Header currentPathname={Astro.url.pathname} />

    <main class="flex-1">
      <section class="relative px-4 pb-20 pt-32 lg:pb-28 lg:pt-40">
        <div class="mx-auto max-w-4xl">
          <h1
            class="mb-4 px-6 text-3xl font-bold tracking-tight text-white md:text-4xl lg:px-8 lg:text-5xl"
          >
            Terms and Conditions
          </h1>

          {formattedDate && (
            <p class="mb-6 px-6 text-sm text-slate-400 lg:px-8">
              Effective Date: {formattedDate}
            </p>
          )}

          {termsData.intro && (
            <p class="mb-8 px-6 text-lg text-slate-300 lg:px-8">
              {termsData.intro}
            </p>
          )}

          {termsData.error ? (
            <div class="px-6 lg:px-8">
              <div class="rounded-lg border border-red-500/30 bg-red-500/10 p-6">
                <p class="text-red-300">Unable to load content. Please try again later.</p>
                <p class="mt-2 text-sm text-red-400/70">{termsData.error}</p>
              </div>
            </div>
          ) : termsData.isEmpty ? (
            <div class="px-6 text-center text-slate-400 lg:px-8">
              <p>No content available yet. Please check back later.</p>
            </div>
          ) : (
            <div class="prose prose-invert mx-auto max-w-none px-6 lg:px-8">
              <div class="tiptap-content" set:html={termsData.htmlContent} />
            </div>
          )}
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .tiptap-content :global(h1) {
    margin-bottom: 1.5rem;
    font-size: 1.875rem;
    line-height: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #ffffff;
  }
  @media (min-width: 768px) {
    .tiptap-content :global(h1) {
      font-size: 2.25rem;
      line-height: 2.5rem;
    }
  }
  @media (min-width: 1024px) {
    .tiptap-content :global(h1) {
      font-size: 3rem;
      line-height: 1;
    }
  }
  .tiptap-content :global(h2) {
    margin-bottom: 1rem;
    margin-top: 2rem;
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 600;
    color: #ffffff;
  }
  .tiptap-content :global(h3) {
    margin-bottom: 0.75rem;
    margin-top: 1.5rem;
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 600;
    color: #ffffff;
  }
  .tiptap-content :global(p) {
    margin-bottom: 1rem;
    color: #94a3b8;
  }
  .tiptap-content :global(ul) {
    margin-bottom: 1rem;
    list-style-position: outside;
    list-style-type: disc;
    color: #94a3b8;
    padding-left: 1.5rem;
  }
  .tiptap-content :global(ol) {
    margin-bottom: 1rem;
    list-style-position: outside;
    list-style-type: decimal;
    color: #94a3b8;
    padding-left: 1.5rem;
  }
  .tiptap-content :global(li) {
    margin-bottom: 0.5rem;
    padding-left: 0.5rem;
  }
  .tiptap-content :global(li > ul),
  .tiptap-content :global(li > ol) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .tiptap-content :global(a) {
    color: #4DB5FF;
    text-decoration: none;
  }
  .tiptap-content :global(a:hover) {
    text-decoration: underline;
  }
  .tiptap-content :global(strong) {
    font-weight: 600;
    color: #ffffff;
  }
  .tiptap-content :global(img) {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 0.5rem;
  }
  .tiptap-content :global(table) {
    margin-bottom: 1.5rem;
    width: 100%;
    border-collapse: collapse;
  }
  .tiptap-content :global(th),
  .tiptap-content :global(td) {
    border: 1px solid #404040;
    padding: 0.75rem;
    text-align: left;
    color: #94a3b8;
  }
  .tiptap-content :global(th) {
    background-color: #262626;
    font-weight: 600;
    color: #ffffff;
  }
  .tiptap-content :global(blockquote) {
    margin-top: 1rem;
    margin-bottom: 1rem;
    border-left-width: 4px;
    border-left-color: #4DB5FF;
    padding-left: 1rem;
    font-style: italic;
    color: #94a3b8;
  }
</style>
