---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  error?: unknown;
}

const { error } = Astro.props as Props;
const errorMessage =
  error instanceof Error ? error.message : "Unexpected server error.";
---

<BaseLayout
  title="Zeustra | Server Error"
  description="Something went wrong while rendering this page."
  canonical="/500"
  noindex={true}
>
  <div class="min-h-screen overflow-x-hidden bg-black text-white">
    <header
      class="fixed top-0 left-0 z-50 w-full min-w-full bg-black/70 backdrop-blur-xl"
    >
      <div class="mx-auto max-w-header px-4">
        <div class="flex h-25 items-center">
          <a
            href="/"
            data-astro-prefetch
            class="flex items-center transition-opacity hover:opacity-80"
          >
            <img
              src="/assets/images/brand/zeustra-logo.svg"
              alt="Zeustra"
              width="212"
              height="103"
              class="h-auto w-40 sm:w-48 md:w-56"
            />
          </a>
        </div>
      </div>
    </header>

    <main class="flex min-h-screen items-center justify-center px-4 pt-25">
      <section
        class="w-full max-w-3xl rounded-2xl border border-white/10 bg-[#0C1017] p-8 text-center sm:p-12"
      >
        <p
          class="text-sm font-medium uppercase tracking-[0.14em] text-brand-blue-light"
        >
          Error 500
        </p>
        <h1 class="mt-4 text-3xl font-semibold text-white sm:text-5xl">
          Server Error
        </h1>
        <p
          class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-slate-300 sm:text-lg"
        >
          Something unexpected happened while rendering this page. Please try
          again, or return to the home page.
        </p>
        <p class="mt-3 text-sm text-slate-400">{errorMessage}</p>

        <div
          class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row"
        >
          <a
            href="/"
            data-astro-prefetch
            class="flex h-12.5 min-w-48 items-center justify-center rounded-full border-[1.25px] border-brand-blue-light bg-linear-to-b from-brand-blue-light to-brand-blue px-6 text-base font-semibold text-neutral-950 transition-all duration-300 hover:shadow-[0_0_25px_rgba(77,181,255,0.7)]"
          >
            Back to Home
          </a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
