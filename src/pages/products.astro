---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/layout/Footer.astro";
import ProductsValueProps from "@/features/products/sections/ProductsValueProps.astro";
import ProductsLayers from "@/features/products/sections/ProductsLayers";
import ProductsTechStack from "@/features/products/sections/ProductsTechStack";
import Header from "../components/layout/Header.astro";
import ProductsHero from "@/features/products/sections/ProductsHero";
import JoinTeamSection from "@/features/products/sections/JoinTeamSection";
import { PAGE_SEO } from "../data/pagesSeo";

const seo = PAGE_SEO.products;
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.path}
>
  <div class="min-h-screen overflow-x-hidden bg-black text-white">
    <Header currentPathname={Astro.url.pathname} />

    <main class="relative flex-1 bg-black">
      <ProductsHero client:load />
      <ProductsTechStack client:load />
      <ProductsLayers client:load />
      <ProductsValueProps />
      <JoinTeamSection client:load />
    </main>

    <Footer />
  </div>
</BaseLayout>
