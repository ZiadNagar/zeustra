---
import BaseLayout from "../layouts/BaseLayout.astro";
import NotFoundEffectsIsland from "../components/islands/NotFoundEffectsIsland";
import { PAGE_SEO } from "../data/pagesSeo";

const HERO_BG = "/assets/images/backgrounds/particle-canvas.webp";
const seo = PAGE_SEO.notFound;
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.path}
  robots={seo.robots}
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={HERO_BG} />
  </Fragment>

  <div class="min-h-screen overflow-x-hidden bg-black text-white">
    <header
      class="fixed top-0 left-0 z-50 w-full min-w-full bg-black backdrop-blur-xl"
    >
      <div class="mx-auto max-w-header px-4">
        <div class="flex h-25 items-center">
          <a
            href="/"
            data-astro-prefetch
            class="flex items-center transition-opacity hover:opacity-80"
          >
            <img
              src="/assets/images/brand/zeustra-logo.svg"
              alt="Zeustra"
              width="212"
              height="103"
              loading="eager"
              class="h-auto w-40 sm:w-48 md:w-56"
            />
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <section class="relative overflow-hidden">
        <NotFoundEffectsIsland client:load />

        <div
          class="absolute inset-0 z-10 h-screen max-h-281.25 w-full bg-cover bg-center"
          style={{ backgroundImage: `url("${HERO_BG}")` }}
        >
        </div>

        <div
          class="relative z-20 flex h-screen max-h-281.25 w-full items-center justify-center pt-25"
        >
          <div
            class="mx-auto w-full max-w-350 px-4 py-8 sm:px-6 sm:py-12 lg:px-8 lg:py-16"
          >
            <div class="flex flex-col items-center gap-8 text-center sm:gap-12">
              <div class="relative w-full">
                <div
                  class="flex flex-col items-center justify-center gap-6 sm:gap-8 lg:gap-10"
                >
                  <div class="flex min-w-full flex-col items-center gap-6">
                    <h1
                      class="font-bold leading-none tracking-tight"
                      style="font-size: clamp(100px, 20vw, 240px)"
                    >
                      <span
                        class="bg-linear-to-r from-brand-cyan to-brand-blue-light bg-clip-text text-transparent"
                        style="text-shadow: 0px 0px 50px rgba(59, 130, 246, 0.6), 0px 0px 16px rgba(0, 212, 255, 0.3)"
                      >
                        404
                      </span>
                    </h1>
                  </div>
                </div>
              </div>

              <h2
                class="max-w-2xl text-[clamp(20px,4vw,48px)] font-medium leading-tight tracking-tight text-slate-50"
              >
                Page Not Found
              </h2>

              <p
                class="max-w-lg text-[clamp(14px,2vw,20px)] leading-relaxed text-slate-300"
              >
                The page you&apos;re looking for doesn&apos;t exist or has been
                moved. Let&apos;s get you back on track.
              </p>

              <div
                class="mt-4 flex flex-col items-center gap-4 sm:flex-row lg:gap-4.25"
              >
                <a
                  href="/"
                  data-astro-prefetch
                  class="flex h-12.5 w-48 items-center justify-center rounded-full border-[1.25px] border-brand-blue-light bg-linear-to-b from-brand-blue-light to-brand-blue text-base leading-[1.032] font-semibold tracking-[0.103%] text-neutral-950 transition-all duration-300 hover:shadow-[0_0_25px_rgba(77,181,255,0.7)] lg:text-[17px]"
                >
                  Back to Home
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
