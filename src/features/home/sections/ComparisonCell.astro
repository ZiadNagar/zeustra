---
export interface Props {
  text: string | undefined;
}
const { text = "" } = Astro.props;

let iconType = "";
let content = text;

if (text.includes("✅")) {
  iconType = "check";
  content = text.replace("✅", "").trim();
} else if (text.includes("❌")) {
  iconType = "cross";
  content = text.replace("❌", "").trim();
} else if (text.includes("⚠")) {
  iconType = "alert";
  content = text.replace("⚠", "").trim();
}
---

<div class="flex items-start justify-center sm:justify-start gap-2.5 text-left w-full h-full">
  {iconType === "check" && (
    <svg class="w-5 h-5 sm:w-6 sm:h-6 shrink-0 text-emerald-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
  )}
  {iconType === "cross" && (
    <svg class="w-5 h-5 sm:w-6 sm:h-6 shrink-0 text-red-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
  )}
  {iconType === "alert" && (
    <svg class="w-5 h-5 sm:w-6 sm:h-6 shrink-0 text-amber-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
  )}
  <span class={iconType === "check" ? "text-emerald-50/90" : "text-neutral-300"}>{content}</span>
</div>