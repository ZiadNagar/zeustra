---
import ServiceCard from "@/components/shared/ServiceCard.astro";
import ServiceCardContent from "@/components/shared/ServiceCardContent.astro";
import ServiceCardDescription from "@/components/shared/ServiceCardDescription.astro";
import ServiceCardHeader from "@/components/shared/ServiceCardHeader.astro";
import ServiceCardIcon from "@/components/shared/ServiceCardIcon.astro";
import ServiceCardImage from "@/components/shared/ServiceCardImage.astro";
import ServiceCardLabel from "@/components/shared/ServiceCardLabel.astro";
import ServiceCardStat from "@/components/shared/ServiceCardStat.astro";
import ServiceCardStats from "@/components/shared/ServiceCardStats.astro";
import ServiceCardTitle from "@/components/shared/ServiceCardTitle.astro";
import { servicesData } from "../data/servicesPageData";

const firstCardStats = [
  { value: "$10 Billion", label: "Transactions" },
  { value: "95%", label: "Close Rate" },
  { value: "15-20%", label: "Added Value" },
];
---

<section class="relative w-full overflow-hidden py-20 sm:py-24 lg:py-32">
  <div class="relative z-10 mx-auto max-w-360 px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center sm:mb-20">
      <h2 class="text-display-lg-alt text-white">
        Product-Led
        <span
          class="text-display-lg-alt bg-linear-to-r from-brand-cyan via-brand-blue-std to-brand-blue-light bg-clip-text text-transparent"
          style="text-shadow: var(--shadow-hero-accent); font-weight: 700;"
        >
          Services
        </span>
      </h2>
      <p
        class="mx-auto mt-4 text-[clamp(16px,2vw,24px)] leading-relaxed text-slate-300 sm:mt-6"
      >
        End-to-end representation across every stage of the transaction
        lifecycle, unifying AI-driven intelligence, strategic positioning, and
        disciplined deal leadership.
      </p>
    </div>

    <div class="flex flex-col gap-4">
      <div class="grid grid-cols-1 gap-4 md:grid-cols-8 lg:grid-cols-12">
        <div class="md:col-span-5 lg:col-span-7">
          <ServiceCard
            variant="default"
            className="h-full bg-neutral-950"
            link="#"
          >
            <ServiceCardHeader className="mb-4">
              <ServiceCardIcon
                src={servicesData[0].icon}
                alt={servicesData[0].heading}
                className="h-12 w-12"
              />
              <ServiceCardLabel>{servicesData[0].label}</ServiceCardLabel>
            </ServiceCardHeader>
            <ServiceCardContent>
              <ServiceCardTitle>{servicesData[0].heading}</ServiceCardTitle>
              <ServiceCardDescription>
                {servicesData[0].paragraph}
              </ServiceCardDescription>
            </ServiceCardContent>
            <ServiceCardImage
              src={servicesData[0].image}
              alt={servicesData[0].heading}
              size="full"
              className="my-4"
            />
            <ServiceCardStats align="center">
              {
                firstCardStats.map((stat) => (
                  <ServiceCardStat value={stat.value} label={stat.label} />
                ))
              }
            </ServiceCardStats>
          </ServiceCard>
        </div>
        <div class="flex flex-col gap-4 md:col-span-3 lg:col-span-5">
          <ServiceCard variant="gradient" link="#">
            <ServiceCardHeader className="mb-3">
              <ServiceCardIcon
                src={servicesData[1].icon}
                alt={servicesData[1].heading}
                className="h-10 w-10"
              />
              <ServiceCardLabel>{servicesData[1].label}</ServiceCardLabel>
            </ServiceCardHeader>
            <ServiceCardContent>
              <ServiceCardTitle>{servicesData[1].heading}</ServiceCardTitle>
              <ServiceCardDescription>
                {servicesData[1].paragraph}
              </ServiceCardDescription>
            </ServiceCardContent>
            <ServiceCardImage
              src={servicesData[1].image}
              alt={servicesData[1].heading}
            />
          </ServiceCard>
          <ServiceCard variant="gradient" link="#">
            <ServiceCardHeader className="mb-3">
              <ServiceCardIcon
                src={servicesData[2].icon}
                alt={servicesData[2].heading}
                className="h-10 w-10"
              />
              <ServiceCardLabel>{servicesData[2].label}</ServiceCardLabel>
            </ServiceCardHeader>
            <ServiceCardContent>
              <ServiceCardTitle>{servicesData[2].heading}</ServiceCardTitle>
              <ServiceCardDescription>
                {servicesData[2].paragraph}
              </ServiceCardDescription>
            </ServiceCardContent>
            <ServiceCardImage
              src={servicesData[2].image}
              alt={servicesData[2].heading}
            />
          </ServiceCard>
        </div>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
        <ServiceCard variant="gradient" link="#">
          <ServiceCardHeader className="mb-3">
            <ServiceCardIcon
              src={servicesData[3].icon}
              alt={servicesData[3].heading}
              className="h-10 w-10"
            />
            <ServiceCardLabel>{servicesData[3].label}</ServiceCardLabel>
          </ServiceCardHeader>
          <ServiceCardContent>
            <ServiceCardTitle>{servicesData[3].heading}</ServiceCardTitle>
            <ServiceCardDescription>
              {servicesData[3].paragraph}
            </ServiceCardDescription>
          </ServiceCardContent>
          <ServiceCardImage
            src={servicesData[3].image}
            alt={servicesData[3].heading}
          />
        </ServiceCard>
        <ServiceCard variant="gradient" link="#">
          <ServiceCardHeader className="mb-3">
            <ServiceCardIcon
              src={servicesData[4].icon}
              alt={servicesData[4].heading}
              className="h-10 w-10"
            />
            <ServiceCardLabel>{servicesData[4].label}</ServiceCardLabel>
          </ServiceCardHeader>
          <ServiceCardContent>
            <ServiceCardTitle>{servicesData[4].heading}</ServiceCardTitle>
            <ServiceCardDescription>
              {servicesData[4].paragraph}
            </ServiceCardDescription>
          </ServiceCardContent>
          <ServiceCardImage
            src={servicesData[4].image}
            alt={servicesData[4].heading}
          />
        </ServiceCard>
        <ServiceCard
          variant="gradient"
          link="#"
          className="sm:col-span-2 md:col-span-1"
        >
          <ServiceCardHeader className="mb-3">
            <ServiceCardIcon
              src={servicesData[5].icon}
              alt={servicesData[5].heading}
              className="h-10 w-10"
            />
            <ServiceCardLabel>{servicesData[5].label}</ServiceCardLabel>
          </ServiceCardHeader>
          <ServiceCardContent>
            <ServiceCardTitle>{servicesData[5].heading}</ServiceCardTitle>
            <ServiceCardDescription>
              {servicesData[5].paragraph}
            </ServiceCardDescription>
          </ServiceCardContent>
          <ServiceCardImage
            src={servicesData[5].image}
            alt={servicesData[5].heading}
          />
        </ServiceCard>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-8 lg:grid-cols-12">
        <div class="md:col-span-5 lg:col-span-7">
          <ServiceCard variant="gradient" className="h-full" link="#">
            <ServiceCardHeader className="mb-3">
              <ServiceCardIcon
                src={servicesData[6].icon}
                alt={servicesData[6].heading}
                className="h-10 w-10"
              />
              <ServiceCardLabel>{servicesData[6].label}</ServiceCardLabel>
            </ServiceCardHeader>
            <ServiceCardContent>
              <ServiceCardTitle>{servicesData[6].heading}</ServiceCardTitle>
              <ServiceCardDescription>
                {servicesData[6].paragraph}
              </ServiceCardDescription>
            </ServiceCardContent>
            <ServiceCardImage
              src={servicesData[6].image}
              alt={servicesData[6].heading}
            />
          </ServiceCard>
        </div>
        <div class="md:col-span-3 lg:col-span-5">
          <ServiceCard variant="gradient" className="h-full" link="#">
            <ServiceCardHeader className="mb-3">
              <ServiceCardIcon
                src={servicesData[7].icon}
                alt={servicesData[7].heading}
                className="h-10 w-10"
              />
              <ServiceCardLabel>{servicesData[7].label}</ServiceCardLabel>
            </ServiceCardHeader>
            <ServiceCardContent>
              <ServiceCardTitle>{servicesData[7].heading}</ServiceCardTitle>
              <ServiceCardDescription>
                {servicesData[7].paragraph}
              </ServiceCardDescription>
            </ServiceCardContent>
            <ServiceCardImage
              src={servicesData[7].image}
              alt={servicesData[7].heading}
            />
          </ServiceCard>
        </div>
      </div>
    </div>
  </div>
</section>
