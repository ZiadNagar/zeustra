---
import { socialChannels } from "@/features/about/data/aboutPageData";
const channel = socialChannels[0];
---

<section
  class="px-4 pb-12 sm:px-6 md:px-8 md:pb-24"
  style="content-visibility:auto;contain-intrinsic-size:320px;"
>
  <div class="container mx-auto max-w-5xl">
    <div
      class="relative overflow-hidden rounded-card-lg border border-border-glass bg-gradient-card backdrop-blur-card transition-all duration-300 md:hover:shadow-glow-blue md:hover:border-brand-blue-std/70"
    >
      <!-- Glow effect -->
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(10,10,10,0.5),transparent_70%)] pointer-events-none"
      >
      </div>

      <div
        class="relative z-10 flex flex-col items-center justify-between gap-8 p-8 text-center md:flex-row md:p-12 md:text-left"
      >
        <div class="max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Access the Zeustra
            <span
              class="bg-linear-to-r from-brand-cyan to-brand-blue-light bg-clip-text text-transparent"
              style="text-shadow:var(--shadow-heading-glow);"
            >
              Network
            </span>
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-slate-300">
            Stay connected to proprietary market intelligence, transaction flow,
            and insights across our platform and marketplace.
          </p>
        </div>

        <div class="shrink-0 flex flex-col items-center text-center">
          <a
            href={channel.href}
            target="_blank"
            rel="noreferrer"
            class="group inline-flex h-12.5 items-center justify-center gap-3 rounded-full bg-linear-to-b from-brand-blue-light to-brand-blue px-8 font-semibold text-black transition-all duration-300 hover:shadow-[0_0_25px_rgba(77,181,255,0.7)]"
          >
            <img src={channel.icon} alt="" aria-hidden="true" class="h-4 w-4" />
            {channel.cta}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
