---
type Props = {
  src: string;
  alt: string;
  className?: string;
};

const { src, alt, className = "" } = Astro.props as Props;
---

<div
  class={`shrink-0 transition-all duration-300 group-hover:scale-110 flex items-center justify-center ${className}`}
>
  <img src={src} alt={alt} class="h-full w-full object-contain" />
</div>
