---
type Props = {
  className?: string;
};

const { className = "" } = Astro.props as Props;
---

<span
  class={`shrink-0 rounded-full px-2.5 py-1 text-xs font-medium tracking-wide text-white sm:text-sm ${className}`}
  style="border:1px solid rgba(33, 213, 237, 0.10);background:rgba(13, 162, 231, 0.05);"
>
  <slot />
</span>
